# ═══════════════════════════════════════════════════════════════
# XenPool IT Selfservice – Umgebungsvariablen
# Kopiere diese Datei nach .env und passe die Werte an.
# .env wird NICHT in Git eingecheckt!
# ═══════════════════════════════════════════════════════════════

# ──────────────────────────────────────────
# Umgebung
# ──────────────────────────────────────────
# development → Mock-Modus aktiv (keine echten externen Aufrufe)
# production  → Echte Systeme werden angesprochen
ENVIRONMENT=development

# ──────────────────────────────────────────
# PostgreSQL
# ──────────────────────────────────────────
POSTGRES_DB=itselfservice
POSTGRES_USER=xpuser
POSTGRES_PASSWORD=changeme_secure_password

# ──────────────────────────────────────────
# Redis
# ──────────────────────────────────────────
# Wird automatisch in docker-compose gesetzt, bei Bedarf überschreiben
# REDIS_URL=redis://redis:6379/0

# ──────────────────────────────────────────
# FastAPI
# ──────────────────────────────────────────
# Secret für JWT / API-Key-Validierung
API_SECRET_KEY=changeme_very_secret_key_min_32_chars
# Erlaubte CORS-Origins (kommagetrennt)
CORS_ORIGINS=http://localhost:3000,http://localhost:8000
# Webhook-Token für ServiceNow (HMAC-Signatur-Validierung)
WEBHOOK_SECRET_TOKEN=changeme_webhook_secret

# ──────────────────────────────────────────
# Celery
# ──────────────────────────────────────────
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# ──────────────────────────────────────────
# Flower (Celery Monitoring)
# ──────────────────────────────────────────
FLOWER_USER=admin
FLOWER_PASSWORD=changeme_flower_password

# ──────────────────────────────────────────
# vSphere
# ──────────────────────────────────────────
VSPHERE_SERVER=vcenter.example.com
VSPHERE_USER=svc-xpool@vsphere.local
VSPHERE_PASSWORD=changeme_vsphere_password
VSPHERE_DATACENTER=DC01
VSPHERE_CLUSTER=CL-VDI
VSPHERE_DATASTORE=DS-VDI
VSPHERE_NETWORK=VLAN-VDI

# ──────────────────────────────────────────
# Active Roles (WinRM)
# ──────────────────────────────────────────
AR_WINRM_HOST=ar-server.example.com
AR_WINRM_PORT=5985
AR_WINRM_USER=svc-xpool@example.com
AR_WINRM_PASSWORD=changeme_ar_password
# AD-Präfix für VDI-Gruppen: z.B. "VDI-RDP-" → "VDI-RDP-VMNAME"
AR_GROUP_PREFIX_RDP=VDI-RDP-
AR_GROUP_PREFIX_ADMIN=VDI-ADM-

# ──────────────────────────────────────────
# SCCM
# ──────────────────────────────────────────
SCCM_WINRM_HOST=sccm-server.example.com
SCCM_WINRM_USER=svc-xpool@example.com
SCCM_WINRM_PASSWORD=changeme_sccm_password
SCCM_TASK_SEQUENCE_ID=TSQ00001
SCCM_SITE_CODE=XP1

# ──────────────────────────────────────────
# E-Mail / SMTP
# ──────────────────────────────────────────
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=noreply@example.com
SMTP_PASSWORD=changeme_smtp_password
SMTP_TLS=true
MAIL_FROM=IT Selfservice <noreply@example.com>
MAIL_FROM_NAME=XenPool IT Selfservice

# ──────────────────────────────────────────
# Scheduling
# ──────────────────────────────────────────
# Stunden vor Ablauf für Erinnerungsmail
REMINDER_HOURS_BEFORE_EXPIRY=24
# Wie oft Ablauf-Check läuft (Cron: stündlich)
EXPIRY_CHECK_CRON=0 * * * *
