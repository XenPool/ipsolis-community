# ═══════════════════════════════════════════════════════════════
# XenPool IT Selfservice – Umgebungsvariablen
# Kopiere diese Datei nach .env und passe die Werte an.
# .env wird NICHT in Git eingecheckt!
# ═══════════════════════════════════════════════════════════════

# ──────────────────────────────────────────
# Umgebung
# ──────────────────────────────────────────
# development → Mock-Modus aktiv (keine echten externen Aufrufe)
# production  → Echte Systeme werden angesprochen
ENVIRONMENT=development

# MOCK_SCRIPTS: Steuert ob DB-Script-Module und Pool-Manager gemockt werden.
# Standard: true wenn ENVIRONMENT=development, false wenn production.
# Auf false setzen um echte Scripts in dev zu testen (Worker neu starten nötig).
# MOCK_SCRIPTS=false

# ──────────────────────────────────────────
# PostgreSQL
# ──────────────────────────────────────────
POSTGRES_DB=itselfservice
POSTGRES_USER=xpuser
POSTGRES_PASSWORD=changeme_secure_password

# ──────────────────────────────────────────
# Redis
# ──────────────────────────────────────────
# Wird automatisch in docker-compose gesetzt, bei Bedarf überschreiben
# REDIS_URL=redis://redis:6379/0

# ──────────────────────────────────────────
# FastAPI
# ──────────────────────────────────────────
# Secret für JWT / API-Key-Validierung
API_SECRET_KEY=changeme_very_secret_key_min_32_chars
# Erlaubte CORS-Origins (kommagetrennt)
# Für prelive: CORS_ORIGINS=https://it-selfservice-pre.xenpool.local
CORS_ORIGINS=http://localhost:3000,http://localhost:8000
# Webhook-Token für ServiceNow (HMAC-Signatur-Validierung)
WEBHOOK_SECRET_TOKEN=changeme_webhook_secret
# Admin-API-Key (X-Admin-Key Header) – vor Production ändern!
ADMIN_API_KEY=changeme_admin_key_min_32_chars

# ──────────────────────────────────────────
# Celery
# ──────────────────────────────────────────
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# ──────────────────────────────────────────
# Flower (Celery Monitoring)
# ──────────────────────────────────────────
FLOWER_USER=admin
FLOWER_PASSWORD=changeme_flower_password
