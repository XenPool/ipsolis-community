# ═══════════════════════════════════════════════════════════════
# Ipsolis – Environment Variables
# Copy this file to .env and adjust the values.
# .env is NOT checked into Git!
# ═══════════════════════════════════════════════════════════════

# ──────────────────────────────────────────
# PostgreSQL
# ──────────────────────────────────────────
POSTGRES_DB=ipsolis
POSTGRES_USER=xpuser
POSTGRES_PASSWORD=changeme_secure_password

# ──────────────────────────────────────────
# FastAPI
# ──────────────────────────────────────────
# Secret for session signing – use a random string of 32+ characters
API_SECRET_KEY=changeme_very_secret_key_min_32_chars
# Allowed CORS origins (comma-separated) – set to your production domain
CORS_ORIGINS=https://selfservice.yourcompany.com
# Webhook token for ServiceNow (HMAC signature validation)
WEBHOOK_SECRET_TOKEN=changeme_webhook_secret
# Admin UI password (X-Admin-Key header / login form)
ADMIN_API_KEY=changeme_admin_key_min_32_chars

# ──────────────────────────────────────────
# Celery
# ──────────────────────────────────────────
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# ──────────────────────────────────────────
# All other settings (AD, SMTP, vSphere, SCCM, Entra ID)
# are configured through the Admin UI: Admin > Settings
# ──────────────────────────────────────────
