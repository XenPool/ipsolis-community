# ═══════════════════════════════════════════════════════════════
# ip·Solis Business Edition — Environment Variables
# Copy this file to .env and fill in every value marked REQUIRED.
# Never commit .env to version control.
# ═══════════════════════════════════════════════════════════════

# ──────────────────────────────────────────
# Image version (optional — defaults to latest)
# Pin to a specific release, e.g. 1.2.0
# ──────────────────────────────────────────
IPSOLIS_VERSION=latest

# ──────────────────────────────────────────
# PostgreSQL                                REQUIRED
# ──────────────────────────────────────────
POSTGRES_DB=ipsolis
POSTGRES_USER=xpuser
POSTGRES_PASSWORD=CHANGE_ME_strong_db_password

# ──────────────────────────────────────────
# FastAPI                                   REQUIRED
# ──────────────────────────────────────────
# Random string, 32+ characters — used for session signing
API_SECRET_KEY=CHANGE_ME_random_secret_32_chars_minimum

# Allowed CORS origin(s) — set to your actual domain
CORS_ORIGINS=https://ipsolis.yourcompany.com

# Admin UI password (login form + X-Admin-Key header)
ADMIN_API_KEY=CHANGE_ME_admin_key_32_chars_minimum

# ──────────────────────────────────────────
# Celery (pre-configured, change only if Redis is external)
# ──────────────────────────────────────────
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# ──────────────────────────────────────────
# Flower monitoring UI                      REQUIRED
# ──────────────────────────────────────────
FLOWER_USER=admin
FLOWER_PASSWORD=CHANGE_ME_flower_password

# ──────────────────────────────────────────
# All other settings
# (Active Directory, SMTP, vSphere, XenServer, SCCM, Entra ID)
# are configured at runtime via the Admin UI:
#   https://ipsolis.yourcompany.com/ui/settings
# ──────────────────────────────────────────
